DATABASE_URI=postgres://user:pass@localhost:5432/ardmore
PAYLOAD_SECRET=change-me-to-a-long-random-string
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Firecrawl (migration only)
FIRECRAWL_API_KEY=

# Resend (transactional email for form submissions)
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@ardmoreshops.com
CONTACT_EMAIL=info@ardmoreshops.com

# S3-compatible storage (Cloudflare R2). Leave empty in dev to use local disk.
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_REGION=auto
